# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Redis
REDIS_URL=redis://localhost:6379

# Database (matches infrastructure/docker/docker-compose.yml)
DATABASE_URL=postgresql://examidentity:localpassword@localhost:5432/examidentity_dev
# Repository source: 'postgres' (default) or 'mock' to run without a database
DATA_SOURCE=postgres

# JWT
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_EXPIRES_IN=12h
# Shared secret to mint university/reviewer dev tokens (MVP only)
DEV_AUTH_SECRET=dev-auth-secret-change-me
# k-anonymity threshold for public metrics (default 5). Set to 1 in dev to see live numbers.
K_ANONYMITY=5

# Platform DID
PLATFORM_DID=did:key:your_platform_did
PLATFORM_PRIVATE_KEY=your_platform_private_key
# Key used to encrypt STANDARD-custody student private keys at rest
PLATFORM_ENCRYPTION_KEY=dev-platform-encryption-key-change-me

# OAuth (for university SSO)
OAUTH_CLIENT_ID=your_oauth_client_id
OAUTH_CLIENT_SECRET=your_oauth_client_secret
OAUTH_CALLBACK_URL=http://localhost:3001/auth/callback

# Scoring Service
SCORING_SERVICE_URL=http://localhost:8000

# Realtime Service
REALTIME_SERVICE_URL=http://localhost:8080

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ExamIdentity API — production environment
# Copy to your host's env config. DO NOT commit real values.

# Core
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Web origin (CORS) — your deployed frontend URL
FRONTEND_URL=https://your-web-app.example.com
# Base URL of THIS api (used in QR verification links)
PUBLIC_BASE_URL=https://your-api.example.com

# Database (managed Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/examidentity
DATA_SOURCE=postgres

# Auth / crypto — generate strong random values
JWT_SECRET=CHANGE_ME_min_32_random_chars
JWT_EXPIRES_IN=12h
PLATFORM_ENCRYPTION_KEY=CHANGE_ME_strong_random_secret
# Stable Ed25519 private key (hex) for signing credentials.
# If unset, a new key is generated each boot and previously issued
# credentials cannot be verified against the current key.
PLATFORM_PRIVATE_KEY=CHANGE_ME_hex_ed25519_private_key
PLATFORM_DID=did:key:zYourPlatformDid

# Privacy
K_ANONYMITY=5

# MVP only: allow university/reviewer dev tokens in production (no SSO yet).
# Set to true ONLY for the MVP demo; remove once real SSO is in place.
ALLOW_DEV_TOKEN=true
DEV_AUTH_SECRET=CHANGE_ME_random_secret

# Optional services (API has fallbacks if absent)
SCORING_SERVICE_URL=https://your-scoring.example.com
REALTIME_SERVICE_URL=https://your-realtime.example.com
REDIS_URL=redis://HOST:6379

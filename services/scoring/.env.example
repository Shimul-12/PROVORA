# Service config
PORT=8000
DEBUG=true

# API service
API_SERVICE_URL=http://localhost:3001
API_SERVICE_SECRET=shared_secret_between_services

# Redis (for session state)
REDIS_URL=redis://localhost:6379

# Thresholds
GAZE_AWAY_THRESHOLD_SECONDS=3
TYPING_SIMILARITY_THRESHOLD=0.75
SYSTEMIC_EVENT_PERCENTAGE=0.15
